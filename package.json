{
  "name": "deslop",
  "version": "0.1.0",
  "private": true,
  "description": "Static repo scanner for fake completeness, vague product copy, weak errors, dead links, client-side auth signals, and unfinished code paths.",
  "license": "UNLICENSED",
  "homepage": "https://deslop.imagineqira.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheArtOfSound/DeSlop.git"
  },
  "bugs": {
    "url": "https://github.com/TheArtOfSound/DeSlop/issues"
  },
  "keywords": [
    "static-analysis",
    "repo-scanner",
    "github-actions",
    "cli-tool",
    "code-audit",
    "quality-gate",
    "product-copy",
    "security-review",
    "developer-tools",
    "ai-code-review"
  ],
  "scripts": {
    "clean": "rm -rf dist dist-page",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "check": "npm run clean && npm run build && node --test dist/*.test.js",
    "audit": "npm run build && node dist/cli.js",
    "build:page": "node scripts/build-public-page.mjs",
    "verify:page": "node scripts/verify-public-page.mjs .",
    "verify:page:dist": "node scripts/verify-public-page.mjs dist-page"
  },
  "bin": {
    "deslop": "dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
