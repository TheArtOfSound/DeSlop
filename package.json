{
  "name": "deslop",
  "version": "0.1.0",
  "private": true,
  "description": "Repo scanner for vague product copy, placeholder code, and fake-complete AI app residue.",
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rm -rf dist dist-page",
    "build": "tsc -p tsconfig.json",
    "check": "npm run clean && npm run build && node --test \"dist/**/*.test.js\"",
    "audit": "npm run build && node dist/cli.js",
    "build:page": "node scripts/build-public-page.mjs",
    "verify:page": "node scripts/verify-public-page.mjs .",
    "verify:page:dist": "node scripts/verify-public-page.mjs dist-page"
  },
  "bin": {
    "deslop": "dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
